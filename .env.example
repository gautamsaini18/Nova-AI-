# Nova AI — Environment Configuration
# Copy this file to .env and fill in your API keys

# ─── App ────────────────────────────────────────────────────────────────
APP_NAME="Nova AI"
APP_VERSION="1.0.0"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-32-chars-min
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ─── API Server ─────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ─── OpenAI ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_TTS_VOICE=nova
OPENAI_STT_MODEL=whisper-1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MAX_TOKENS=4096
TEMPERATURE=0.7

# ─── ElevenLabs TTS ─────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ─── Porcupine Wake Word ─────────────────────────────────────────────────
PORCUPINE_ACCESS_KEY=
WAKE_WORD=hey nova
WAKE_WORD_SENSITIVITY=0.5

# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./nova_ai.db
POSTGRES_URL=
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=nova_memory

# ─── Firebase ───────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ─── Weather ────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=
DEFAULT_CITY=New Delhi
DEFAULT_COUNTRY_CODE=IN

# ─── News ───────────────────────────────────────────────────────────────
NEWS_API_KEY=

# ─── Google Services ────────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ─── Communication ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SLACK_BOT_TOKEN=
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# ─── Vision ─────────────────────────────────────────────────────────────
ENABLE_CAMERA=false
CAMERA_DEVICE_INDEX=0

# ─── Smart Home ─────────────────────────────────────────────────────────
HOMEKIT_ENABLED=false
GOOGLE_HOME_ENABLED=false

# ─── Memory / Context ───────────────────────────────────────────────────
MAX_CONTEXT_MESSAGES=20
MAX_MEMORY_ENTRIES=1000
MEMORY_SIMILARITY_THRESHOLD=0.75

# ─── Audio ──────────────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_SIZE=1024
NOISE_REDUCTION_ENABLED=true

# ─── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/nova_ai.log
LOG_ROTATION=10 MB

# ─── Rate Limiting ──────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
